DIRECT_URL=""
# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET=""   # generate with: openssl rand -base64 32
AUTH_TRUST_HOST="true"
# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="flux-attachments"
# SMTP (invite emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Flux <no-reply@foodverse.io>"
