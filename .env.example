# Database — local Postgres 16 (e.g. postgresql://<you>@localhost:5432/flux_dev) or hosted (Neon/Supabase).
# For Supabase use the pooled URL as DATABASE_URL and the direct URL as DIRECT_URL. For Neon both can be the same.
DATABASE_URL=""
DIRECT_URL=""
# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET=""   # generate with: openssl rand -base64 32
AUTH_TRUST_HOST="true"
# Seed admin (dev/e2e only) — password the seed script assigns to it@iccadubai.ae; the e2e suite signs in with it
SEED_ADMIN_PASSWORD=""
# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="flux-attachments"
# SMTP (invite emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Flux <no-reply@foodverse.io>"
# Cron auth — shared secret the scheduler sends as `Authorization: Bearer <value>` to /api/cron/due-reminders
CRON_SECRET=""
